# Public host/ports
# Set SERVER_HOST to server LAN IP/domain, then update public URLs below.
SERVER_HOST=localhost
FRONTEND_PORT=3000
BACKEND_PORT=8000
MINECRAFT_PORT=25565
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# JWT
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/mc_manager.db

# Data paths
DATA_DIR=/app/data
LOGS_DIR=/app/logs

# Initial admin user (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
